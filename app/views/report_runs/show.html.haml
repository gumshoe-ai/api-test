- if @error
  .alert.alert-danger
    %strong Error:
    = @error
- else
  = link_to "← Back to Report Runs", report_runs_path(report_id: @report_id), class: "btn btn-secondary"
  = link_to "View Raw", raw_report_run_path(report_id: @report_id, ordinal: params[:ordinal] || params[:id]), class: "btn btn-primary", style: "margin-left: 10px;"
  %h1 Report Run Details (Report ##{@report_id}, Ordinal: #{params[:ordinal] || params[:id]})
  
  - if @curl_command
    .debug-info{style: "background: #f0f0f0; padding: 15px; margin: 20px 0; border-radius: 4px; font-family: monospace; font-size: 12px;"}
      %strong CURL Command to test API:
      %br
      %code{style: "background: #fff; padding: 10px; display: block; margin: 10px 0; border: 1px solid #ddd; border-radius: 4px; word-break: break-all;"}
        = @curl_command
  
  - if @report_run
    .report-run-details
      %dl
        - @report_run.each do |key, value|
          %dt= key.to_s.humanize
          %dd
            - if value.is_a?(Hash) || value.is_a?(Array)
              %pre= JSON.pretty_generate(value)
            - else
              = value
  - else
    %p Report run not found.

